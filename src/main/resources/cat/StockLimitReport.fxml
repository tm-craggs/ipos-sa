<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="450.0" prefWidth="993.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cat.StockLowLevelManager">
    <top>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="15.0" right="15.0" top="15.0" />
            </padding>

            <HBox alignment="CENTER_LEFT">
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Stock Limit Report" />
                <Pane HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#writeExcel" prefHeight="30.0" text="Export as CSV" />
            </HBox>

            <Separator />
        </VBox>
    </top>

    <center>
        <TableView fx:id="StockLimitReport" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn prefWidth="174.0" text="Item ID">
                    <cellValueFactory><PropertyValueFactory property="itemId" /></cellValueFactory>
                </TableColumn>
                <TableColumn prefWidth="190.0" text="Description">
                    <cellValueFactory><PropertyValueFactory property="description" /></cellValueFactory>
                </TableColumn>
                <TableColumn prefWidth="182.0" text="Availability, packs">
                    <cellValueFactory><PropertyValueFactory property="availability" /></cellValueFactory>
                </TableColumn>
                <TableColumn prefWidth="189.0" text="Stock limit, packs">
                    <cellValueFactory><PropertyValueFactory property="stockLimit" /></cellValueFactory>
                </TableColumn>
                <TableColumn prefWidth="240.0" text="Recommended Min Order">
                    <cellValueFactory><PropertyValueFactory property="recommended" /></cellValueFactory>
                </TableColumn>
            </columns>
            <BorderPane.margin>
                <Insets bottom="15.0" left="15.0" right="15.0" />
            </BorderPane.margin>
        </TableView>
    </center>
</BorderPane>