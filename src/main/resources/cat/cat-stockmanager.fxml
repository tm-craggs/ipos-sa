<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="698.0" prefWidth="994.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cat.CatalougeManager">
    <top>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <ToolBar style="-fx-background-color: #34495e;">
                <Button onAction="#handleBack" text="← Back to Main Menu" style="-fx-text-fill: white; -fx-background-color: #2c3e50;"/>
                <Pane HBox.hgrow="ALWAYS" />
                <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Logout" />
            </ToolBar>

            <VBox spacing="10.0">
                <padding>
                    <Insets left="15.0" right="15.0" />
                </padding>
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="IPOS-SA Catalogue Management" />
                <Separator />

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Button fx:id="addItemButton" mnemonicParsing="false" onAction="#handleAddItem" prefHeight="25.0" prefWidth="100.0" text="Add item" />
                    <Button fx:id="editItemButton" mnemonicParsing="false" onAction="#handleEditItem" prefHeight="25.0" prefWidth="100.0" text="Edit item" />
                    <Button fx:id="deleteItemButton" mnemonicParsing="false" onAction="#handleDeleteItem" prefHeight="25.0" prefWidth="100.0" text="Delete item" />
                    <Pane HBox.hgrow="ALWAYS" />
                    <Button fx:id="addStockButton" mnemonicParsing="false" onAction="#handleAddStock" prefHeight="25.0" prefWidth="100.0" text="Add stock" />
                    <Button fx:id="lowStockReportButton" mnemonicParsing="false" onAction="#handleLowStock" prefHeight="25.0" prefWidth="130.0" text="Low Stock Report" />
                </HBox>

                <TextField fx:id="searchField" prefHeight="35.0" promptText="Search by item Id, description..." />
                <Label fx:id="warningLabel" text="" textFill="RED" />
            </VBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tableView" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="colId" prefWidth="71.0" text="ID">
                    <cellValueFactory><PropertyValueFactory property="itemId" /></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colDesc" prefWidth="180.0" text="Description">
                    <cellValueFactory><PropertyValueFactory property="description" /></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colPackageType" prefWidth="103.0" text="Package Type">
                    <cellValueFactory><PropertyValueFactory property="packageType" /></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colUnit" prefWidth="89.0" text="Unit">
                    <cellValueFactory><PropertyValueFactory property="unit" /></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colUnitsPerPack" prefWidth="117.0" text="Units/Pack">
                    <cellValueFactory><PropertyValueFactory property="unitsPerPack" /></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colPackageCost" prefWidth="102.0" text="Package Cost">
                    <cellValueFactory><PropertyValueFactory property="packageCost" /></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colAvailability" prefWidth="138.0" text="Availability">
                    <cellValueFactory><PropertyValueFactory property="availability" /></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colStockLimit" prefWidth="80.0" text="Stock Limit">
                    <cellValueFactory><PropertyValueFactory property="stockLimit" /></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colStatus" prefWidth="80.0" text="Status">
                    <cellValueFactory><PropertyValueFactory property="status" /></cellValueFactory>
                </TableColumn>
            </columns>
            <BorderPane.margin>
                <Insets left="15.0" right="15.0" />
            </BorderPane.margin>
        </TableView>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <Label fx:id="totalItemsLabel" text="Total items:" />
            <Label fx:id="selectedLabel" text="Selected:" />
            <Pane HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>
</BorderPane>